OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
USE_LOCAL_FALLBACK=true
APP_ENV=development
REQUIRE_API_KEY=false
API_KEYS=
ADMIN_API_KEYS=
API_KEY_HASHES=
ADMIN_API_KEY_HASHES=
TRUSTED_PROXY_AUTH_ENABLED=false
TRUSTED_PROXY_AUTH_SECRET=
TRUSTED_PROXY_SECRET_HEADER=X-ServiceGuard-Proxy-Secret
TRUSTED_PROXY_USER_HEADER=X-ServiceGuard-User
TRUSTED_PROXY_ROLE_HEADER=X-ServiceGuard-Role
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
MAX_UPLOAD_MB=20
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
DATA_RETENTION_DAYS=30
AUDIT_RETENTION_DAYS=180
VECTOR_DB=chroma
CHROMA_DIR=./data/chroma
SQLITE_URL=sqlite:///./data/serviceguard.db
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_JOURNAL_MODE=WAL
SQLITE_SYNCHRONOUS=NORMAL
UPLOAD_DIR=./data/uploads
BACKUP_DIR=./data/backups
BACKUP_SIGNING_KEY=
QUARANTINE_PROMPT_INJECTION_DOCUMENTS=true
PROMPT_VERSION=v0.1
CHUNK_SIZE=700
CHUNK_OVERLAP=120
TOP_K=5
MAX_BATCH_ROWS=500
BATCH_JOB_TIMEOUT_SECONDS=300
MAX_ACTIVE_BATCH_JOBS=20
MAX_ACTIVE_BATCH_JOBS_PER_ACTOR=3
LOG_LEVEL=INFO
